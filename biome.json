{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": ["**", "!**/node_modules", "!**/dist", "!**/build", "!**/.turbo", "!**/.next"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "correctness": {
                "noUnusedImports": "error",
                "noUnusedVariables": "error"
            },
            "security": {
                "noGlobalEval": "error"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useNodejsImportProtocol": "error"
            }
        }
    }
}
